# include <stdio.h>

int main(){

    char estado1[3], estado2[3], codigo1[4], codigo2[4], cidade1[30], cidade2[30];
    long int pop1, pop2, pt1, pt2;
    float area1 , area2, pib1, pib2, dens1,dens2, pc1, pc2, SP1, SP2;

    //dens = densidade populacional
    //SP = Super Trunfo
    //pc = PIB per capita
    //pt = pontos turísticos
    //pop = população


    //Cidade 1
    printf("Digite o estado(sigla) da cidade 1.\n");
    scanf("%s", estado1);

    printf("Digite o código da cidade 1.\n");
    scanf("%s", codigo1);

    printf("Digite o nome da da cidade 1.\n");
    scanf("%s", cidade1);

    printf("Digite a população da cidade 1.\n");
    scanf("%ld", &pop1);

    printf("Digite a área em km² da cidade 1.\n");
    scanf("%f", &area1);

    printf("Digite o PIB em reais da cidade 1.\n");
    scanf("%f", &pib1);

    printf("Digite o número de pontos turísticos da cidade 1.\n");
    scanf("%ld", &pt1);

    dens1 = (float) pop1/ area1;
    pc1 = (float) pib1/pop1;
    SP1 = (float) pop1 + area1 + pib1 + pt1 + pc1 + (1/dens1);

    //Cidade 2
    printf("Digite o estado(sigla) da cidade 2.\n");
    scanf("%s", estado2);

    printf("Digite o código da cidade 2.\n");
    scanf("%s", codigo2);

    printf("Digite o nome da da cidade 2.\n");
    scanf("%s", cidade2);

    printf("Digite a população da cidade 2.\n");
    scanf("%ld", &pop2);

    printf("Digite a área em km² da cidade 2.\n");
    scanf("%f", &area2);

    printf("Digite o PIB em reais da cidade 2.\n");
    scanf("%f", &pib2);

    printf("Digite o número de pontos turísticos da cidade 2.\n");
    scanf("%ld", &pt2);

    dens2 =(float) pop2 / area2;
    pc2 = (float) pib2 / pop2;
    SP1 = (float) pop2 + area2 + pib2 + pt2 + pc2 + (1/dens2);

    if(pop1 > pop2){
        printf("A população da cidade de %s é maior qua a da cidade de %s. A carta 1 venceu! \n", cidade1, cidade2);
    } else{
        printf("A população da cidade de %s é maior que a da cidade de %s. A carta 2 venceu! \n", cidade2, cidade1);
    }
    
    if(area1 > area2){
        printf("A area da cidade de %s é maior qua a da cidade de %s. A carta 1 venceu! \n", cidade1, cidade2);
    } else{
        printf("A area da cidade de %s é maior que a da cidade de %s. A carta 2 venceu! \n", cidade2, cidade1);
    }

    if(pib1 > pib2){
        printf("O PIB da cidade de %s é maior qua a da cidade de %s. A carta 1 venceu! \n", cidade1, cidade2);
    } else{
        printf("O PIB da cidade de %s é maior que a da cidade de %s. A carta 2 venceu! \n", cidade2, cidade1);
    }

    if(pt1 > pt2){
        printf("O número de pontos turísticos da cidade de %s é maior qua a da cidade %s. A carta 1 venceu! \n", cidade1, cidade2);
    } else{
        printf("O número de pontos turísticos da cidade de %s é maior que a da cidade %s. A carta 2 venceu! \n", cidade2, cidade1);
    }

    if(dens1 < dens2){
        printf("A densidade populacional da cidade de %s é menor qua a da cidade %s. A carta 1 venceu! \n", cidade1, cidade2);
    } else{
        printf("A densidade populacional da cidade de %s é menor que a da cidade %s. A carta 2 venceu! \n", cidade2, cidade1);
    }

    if(pc1 > pc2){
        printf("O PIB per capita da cidade de %s é maior qua a da cidade de %s. A carta 1 venceu! \n", cidade1, cidade2);
    } else{
        printf("O PIB per capita da cidade de %s é maior que a da cidade de %s. A carta 2 venceu! \n", cidade2, cidade1);
    }

    
    return 0;

}
